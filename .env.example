# Supabase (required)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# App URL (used for invite link generation)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Admin page secret — visit /invites?key=YOUR_KEY to see all invite links
ADMIN_SECRET_KEY=change-me-to-a-secure-random-string

# Cron job security — Vercel sends Authorization: Bearer <CRON_SECRET>
CRON_SECRET=change-me-to-a-secure-random-string

# API-Football key — get yours at https://www.api-football.com/
# Required for live-first /api/sync-team-status (falls back to snapshot without it)
API_FOOTBALL_KEY=your-api-football-key-here

# worldcup26.ir secondary enrichment (fixture dates, stadiums, group labels)
# Set WORLD_CUP26_ENABLED=false to disable. Never overrides verified qualification.
WORLD_CUP26_BASE_URL=https://worldcup26.ir
WORLD_CUP26_ENABLED=true
WORLD_CUP26_CACHE_TTL_MS=900000
WORLD_CUP26_MAX_DATA_AGE_MS=43200000
