# Supabase (required)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# App URL (used for invite link generation)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Admin page secret — visit /invites?key=YOUR_KEY to see all invite links
ADMIN_SECRET_KEY=change-me-to-a-secure-random-string

# Cron job security — Vercel sends Authorization: Bearer <CRON_SECRET>
CRON_SECRET=change-me-to-a-secure-random-string

# World Cup auto-update provider: noop (default) | api-football | custom
WORLD_CUP_PROVIDER=noop

# Future: API key for external tournament data provider
# API_FOOTBALL_KEY=
